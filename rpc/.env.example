# ========================================
# Token Airdrop DApp - Environment Config
# ========================================

# Deployer / Admin private key (DO NOT commit with real keys)
PRIVATE_KEY=

# Infura API key (get one at https://app.infura.io)
INFURA_API_KEY=

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=

# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Deployed contract addresses (filled after deployment)
TOKEN_ADDRESS=
AIRDROP_ADDRESS=
USDT_ADDRESS=
SWAP_ADDRESS=
